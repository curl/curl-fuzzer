# HTTP POST under tight backpressure. A ~16KB POSTFIELDS body outruns the
# SO_RCVBUF=2048 mock-side kernel buffer (Linux doubles SNDBUF minima so
# smaller payloads still fit in one send()), while DrainIncoming only
# drains 32 bytes per loop tick. curl_easy_perform keeps hitting
# CURLE_AGAIN on the request-body send(). Exercises the partial-write
# retry loop in sendf.c / cf-socket.c that the short-response scenarios
# never reach. Server eventually 200s once the mock has drained the body.
scheme: SCHEME_HTTP
host_path: "127.0.0.1/post-bp"
options { option_id: CURLOPT_POST bool_value: true }
options { option_id: CURLOPT_POSTFIELDS string_value: "" }
connection {
  initial_response: "HTTP/1.1 200 OK\r\nContent-Length: 2\r\n\r\nOK"
  backpressure {
    recv_buf_bytes: 2048
    drain_limit: 256
  }
}
