# Single non-final CLOSE frame (FIN=0, opcode 0x08). ws_frame_firstbyte2flags
# rejects fragmented CLOSE with a dedicated failf() on firstbyte 0x08.
# (Split out of ws_nonfinal_control.textproto because the first bad frame
# closes the connection before later frames are parsed.)
scheme: SCHEME_WS
host_path: "127.0.0.1/nonfinal-close"
connection {
  server_frames {
    fin: false
    opcode: 8       # CLOSE with FIN=0 → rejected as fragmented CLOSE
    payload: "\x03\xe8"
  }
}
