{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":assignAndReview(cmeister2)"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "extractVersionTemplate": "^v?(?<version>.*)$",
      "managerFilePatterns": [
        "CMakeLists.txt"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\r?\\n\\s*set\\([A-Z0-9_]+_VERSION (?<currentValue>\\d+\\.\\d+\\.\\d+)\\)"
      ]
    },
    {
      "customType": "regex",
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "openldap/openldap",
      "extractVersionTemplate": "^OPENLDAP_REL_ENG_(?<major>\\d+)_(?<minor>\\d+)_(?<patch>\\d+)$",
      "managerFilePatterns": [
        "CMakeLists.txt"
      ],
      "matchStrings": [
        "# Install OpenLDAP\\nset\\(OPENLDAP_VERSION (?<currentValue>.*)\\)"
      ],
      "versioningTemplate": "semver"
    }
  ],
  "packageRules": [
    {
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "GitHub Actions"
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "matchPackageNames": [
        "google/oss-fuzz"
      ],
      "enabled": false
    },
    {
      "matchManagers": [
        "pep621"
      ],
      "groupName": "Python dependencies"
    },
    {
      "matchManagers": [
        "custom.regex"
      ],
      "matchPackageNames": [
        "openssl/openssl"
      ],
      "extractVersion": "^openssl-(?<version>.*)$"
    }
  ]
}
